{
  "name": "webhook-catcher",
  "version": "0.1.0",
  "description": "Catch webhooks, transform payloads with JSONata, and forward them to other webhooks",
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "fastify": "^5.2.0",
    "jsonata": "^2.0.6",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
